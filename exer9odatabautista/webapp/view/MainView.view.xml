<mvc:View controllerName="sapips.training.exer9odatabautista.controller.MainView" xmlns:mvc="sap.ui.core.mvc" displayBlock="true" xmlns="sap.m">

    <Page id="page" title="{i18n>pageTitle}">

        <Table
            id="tableProducts"
            items="{
                path: '/Products',
                sorter: {
                path: 'ProductName'
                    },
                filters: [{
                path: 'Discontinued',
                operator: 'EQ',
                value1: false
                }]
            }">

            <headerToolbar>
                <Toolbar id="_IDGenToolbar">
                    <Title id="_IDGenTitle1" text="{i18n>headTitle}" level="H2"/>
                </Toolbar>
            </headerToolbar>
            <infoToolbar>
                <Toolbar id="productsInfoToolbar">
                    <Title id="_IDGenTitle2" text="{i18n>infoTitle}" level="H2" class="italicTitle"/>
                </Toolbar>
            </infoToolbar>

            <columns>
                <Column id="_IDGenColumn">
                    <Text id="_IDGenText" text="{i18n>col1Title}"/>
                </Column>

                <Column id="_IDGenColumn1">
                    <Text id="_IDGenText1" text="{i18n>col2Title}"/>
                </Column>

                <Column id="_IDGenColumn2">
                    <Text id="_IDGenText2" text="{i18n>col3Title}"/>
                </Column>
            </columns>

            <items>
                <ColumnListItem id="_IDGenColumnListItem">
                    <cells>
                        <ObjectIdentifier id="_IDGenObjectIdentifier"
                            title="{ProductName}"
                            text="{i18n>rowDat1}: {ProductID}" />

                        <Text id="_IDGenText3" text="{SupplierID}" />

                        <ObjectIdentifier id="_IDGenObjectIdentifier1"
                            title="{UnitPrice}"
                            text="{QuantityPerUnit}" />

                    </cells>
                </ColumnListItem>
            </items>

        </Table>

    </Page>
</mvc:View>